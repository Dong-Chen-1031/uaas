---
import { AlertCircle } from "lucide-astro";
---

<div class="bg-black text-white py-3 px-4 text-sm font-medium">
    <div class="max-w-4xl mx-auto flex items-center justify-center gap-2">
        <AlertCircle size={16} class="text-yellow-400 shrink-0" />
        <p class="leading-tight">
            <span
                class="inline-block px-2 py-0.5 bg-yellow-400 text-black text-xs font-bold rounded mr-2 uppercase shrink-0 whitespace-nowrap"
                >Emergency</span
            >
            Staffing emergency: Our Head of Randomness has been placed on administrative
            leave after attempting to predict the next UUID. We are currently using
            a backup D20 die.
        </p>
    </div>
</div>
