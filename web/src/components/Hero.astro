    <div
        class="mb-8 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-blue-700 text-[min(2.7vw,0.875rem)] font-medium">
        <span class="flex h-2 w-2 rounded-full bg-blue-600"></span>
        We've raised a $20M seed round to generate strings.
    </div>

    <h1
        class="text-[min(10vw,6rem)] font-black tracking-tighter text-gray-900 mb-8 leading-[1.2]">
        STOP GENERATING <span class="bg-black text-white px-2 my-1">UUIDs</span> LOCALLY.
    </h1>

    <p
        class="text-xl md:text-2xl text-gray-600 mb-12 max-w-3xl mx-auto font-medium leading-relaxed">
        It's 2026. Your CPU has better things to do than shuffle bits. Outsource
        your primary keys to our <span
            class="text-black bg-gradient-to-t from-yellow-400/60 from-[35%] to-transparent to-[35%] [box-decoration-break:clone] [-webkit-box-decoration-break:clone]"
            >proprietary cluster of high-entropy interns.</span
        >
    </p>

    <div class="flex flex-col items-center gap-6">
        <div
            class="bg-gray-900 text-gray-300 p-8 rounded-2xl font-mono text-left w-full max-w-xl shadow-[0_20px_50px_rgba(0,0,0,0.3)] border border-white/10 relative overflow-x-auto group">
            <div
                class="absolute inset-0 bg-gradient-to-tr from-blue-500/10 to-transparent">
            </div>
            <div class="flex gap-2 mb-6 relative">
                <div class="w-3.5 h-3.5 rounded-full bg-[#FF5F56]"></div>
                <div class="w-3.5 h-3.5 rounded-full bg-[#FFBD2E]"></div>
                <div class="w-3.5 h-3.5 rounded-full bg-[#27C93F]"></div>
            </div>
            <div class="relative">
                <p class="text-base">{"{"}</p>
                <div class="pl-6 space-y-1">
                    <p class="text-base text-green-400">
                        "uuid": "<span id="uuid-value" class="break-all"
                            >34422870-3cb2-4901-bad1-5c3a616b84df</span
                        >",
                    </p>
                    <p class="text-base text-blue-400">"version": 4,</p>
                    <p class="text-base text-purple-400">
                        "method": "Web-Scale Cryptographic Randomness",
                    </p>
                    <p class="text-base text-yellow-400">
                        "deduplicated": true,
                    </p>
                    <p class="text-base text-gray-400 italic">
                        "sponsored_by": "<span id="sponsor-value"
                            >CloudStrike</span
                        >"
                    </p>
                </div>
                <p class="text-base">{"}"}</p>
            </div>

            <button
                id="try-uuid"
                class="absolute right-6 bottom-6 bg-white text-black px-8 py-3 rounded-xl text-md font-black shadow-[0_4px_0_0_#ddd] hover:shadow-none hover:translate-y-1 transition-all active:scale-95">
                GENERATE NOW
            </button>
        </div>
        <div class="flex flex-col items-center gap-2">
            <p
                class="text-sm font-bold text-gray-400 tracking-tighter uppercase">
                * Zero collisions since the intern started last Tuesday.
            </p>
            <div class="flex gap-2">
                <div
                    class="px-2 py-0.5 bg-gray-200 text-[10px] font-bold rounded">
                    SOC2 Type NONE
                </div>
                <div
                    class="px-2 py-0.5 bg-gray-200 text-[10px] font-bold rounded">
                    HIPAA COMPLAINT
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const btn = document.querySelector("#try-uuid");
    const display = document.querySelector("#uuid-value");
    const sponsorDisplay = document.querySelector("#sponsor-value");

    const sponsors = [
        "VoidCorp",
        "Mars-Bound Interns",
        "Entropy-Flow",
        "Glitch-O-Matic",
        "Synthetica",
        "BreadBoard Enthusiasts",
        "StaticNoise",
        "Z-Coordinate Labs",
        "Zero-Value Ventures",
        "Infinite-Monkey-Typewriters",
    ];

    btn?.addEventListener("click", () => {
        if (display) {
            // Generating a fake UUID for the UI component
            const newUuid = crypto.randomUUID();
            display.textContent = newUuid;

            if (sponsorDisplay) {
                const randomSponsor =
                    sponsors[Math.floor(Math.random() * sponsors.length)];
                sponsorDisplay.textContent = randomSponsor;
            }
        }
    });
</script>
